# OpenCode SaaS Kit - Environment Variables
# Copy this file to .env and fill in your values

# Context7 (optional, for higher rate limits)
CONTEXT7_API_KEY=

# PostgreSQL (for Prisma MCP)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=

# GitHub (optional, for GitHub MCP)
GITHUB_PERSONAL_ACCESS_TOKEN=
